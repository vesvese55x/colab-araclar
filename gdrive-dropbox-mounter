    else
        echo -e "  ${RED}❌ /dev/fuse bulunamadı (container ortamı olabilir)${NC}"
    fi

    echo -e "${BOLD}4. fuse kernel modülü:${NC}"
    if lsmod 2>/dev/null | grep -q fuse; then
        echo -e "  ${GREEN}✅ fuse modülü yüklü${NC}"
    else
        echo -e "  ${YELLOW}⚠️  fuse modülü görünmüyor (modprobe fuse deneyin)${NC}"
    fi

    echo -e "${BOLD}5. Kullanıcı grupları:${NC}"
    echo -e "  Gruplar: $(groups 2>/dev/null)"

    echo -e "${BOLD}6. rclone sürümü:${NC}"
    rclone --version 2>/dev/null | head -1

    echo ""
    print_separator
    echo -e "${BOLD}🛠️  OTOMATİK DÜZELTME MENÜSÜ / AUTO-FIX MENU${NC}"
    echo ""
    echo -e "  ${BOLD}1)${NC} fusermount → fusermount3 symlink oluştur (root/sudo gerekmez)"
    echo -e "  ${BOLD}2)${NC} fuse3 paketini kur (sudo gerekir)"
    echo -e "  ${BOLD}3)${NC} fuse modülünü yükle (sudo modprobe fuse)"
    echo -e "  ${BOLD}4)${NC} /dev/fuse oluştur (sudo, container için)"
    echo -e "  ${BOLD}0)${NC} Geri / Back"
    echo ""
    read -p "$(echo -e "${YELLOW}Seçiminiz / Choice: ${NC}")" fix_choice

    case "$fix_choice" in
        1)
            local fm_path
            fm_path=$(command -v fusermount 2>/dev/null)
            if [ -z "$fm_path" ]; then
                echo -e "${RED}fusermount bulunamadı, önce FUSE kurulmalı.${NC}"
            else
                # Önce kullanıcı PATH'ine dene
                mkdir -p "$HOME/.local/bin"
                ln -sf "$fm_path" "$HOME/.local/bin/fusermount3" 2>/dev/null && {
                    echo -e "${GREEN}✅ $HOME/.local/bin/fusermount3 → $fm_path oluşturuldu${NC}"
                    echo -e "${YELLOW}Not: PATH'e '$HOME/.local/bin' eklendiğinden emin olun.${NC}"
                    echo -e "  export PATH=\"\$HOME/.local/bin:\$PATH\"  >> ~/.bashrc"
                    export PATH="$HOME/.local/bin:$PATH"
                    log "Created fusermount3 symlink in ~/.local/bin"
                } || echo -e "${RED}Symlink oluşturulamadı.${NC}"

                # /usr/local/bin'e de dene (sudo ile)
                sudo ln -sf "$fm_path" /usr/local/bin/fusermount3 2>/dev/null && \
                    echo -e "${GREEN}✅ /usr/local/bin/fusermount3 → $fm_path (sudo ile)${NC}"
            fi
            ;;
        2)
            if command -v apt-get &>/dev/null; then
                sudo apt-get install -y fuse3 fuse
            elif command -v dnf &>/dev/null; then
                sudo dnf install -y fuse fuse3
            elif command -v pacman &>/dev/null; then
                sudo pacman -S --noconfirm fuse3
            else
                echo -e "${RED}Paket yöneticisi tespit edilemedi.${NC}"
            fi
            ;;
        3)
            sudo modprobe fuse 2>/dev/null && \
                echo -e "${GREEN}✅ fuse modülü yüklendi${NC}" || \
                echo -e "${RED}❌ Modül yüklenemedi${NC}"
            ;;
        4)
            echo -e "${YELLOW}Container ortamında /dev/fuse oluşturuluyor...${NC}"
            sudo mknod -m 666 /dev/fuse c 10 229 2>/dev/null && \
                echo -e "${GREEN}✅ /dev/fuse oluşturuldu${NC}" || \
                echo -e "${RED}❌ /dev/fuse oluşturulamadı (--privileged gerekebilir)${NC}"
            ;;
        0) return ;;
    esac

    press_enter
}

