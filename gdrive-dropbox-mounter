#!/bin/bash

# ============================================================
#  RCLONE MOUNT MANAGER - Gelişmiş Sürüm / Advanced Version
#  Google Drive & Dropbox Çoklu Hesap Yöneticisi
#  Multi-Account Mount Manager
# ============================================================

# Renkler / Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Log dosyası
LOG_FILE="$HOME/.rclone_mount_manager.log"

# ============================================================
# YARDIMCI FONKSİYONLAR / HELPER FUNCTIONS
# ============================================================

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║          RCLONE ÇOKLU HESAP MOUNT YÖNETİCİSİ               ║"
    echo "║          RCLONE MULTI-ACCOUNT MOUNT MANAGER                 ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

print_separator() {
    echo -e "${BLUE}──────────────────────────────────────────────────────────────${NC}"
}

press_enter() {
    echo ""
    read -p "$(echo -e "${YELLOW}[ENTER] Ana menüye dön / Return to main menu...${NC}")" dummy
}

# Rclone kurulu mu kontrol et / Check if rclone is installed
check_rclone() {
    if ! command -v rclone &> /dev/null; then
        echo -e "${RED}[HATA] rclone kurulu değil! / [ERROR] rclone is not installed!${NC}"
        echo ""
        echo -e "${YELLOW}Kurulum için / For installation:${NC}"
        echo "  Linux/macOS: curl https://rclone.org/install.sh | sudo bash"
        echo "  veya / or  : sudo apt install rclone  (Debian/Ubuntu)"
        echo "  veya / or  : sudo dnf install rclone  (Fedora/RHEL)"
        echo "  veya / or  : brew install rclone       (macOS)"
        echo ""
        exit 1
    fi
}

# FUSE kontrol et ve gerekirse kur / Check FUSE and install if needed
check_fuse_and_fix() {
    # fusermount3 veya fusermount var mı? / Check for fusermount3 or fusermount
    local fuse_ok=0

    if command -v fusermount3 &>/dev/null; then
        fuse_ok=1
    elif command -v fusermount &>/dev/null; then
        # fusermount var ama fusermount3 yok → symlink oluştur
        fuse_ok=1
        if [ ! -e /usr/local/bin/fusermount3 ] && [ ! -e /usr/bin/fusermount3 ]; then
            echo -e "${YELLOW}[FIX] fusermount3 bulunamadı, fusermount'a symlink oluşturuluyor...${NC}"
            echo -e "${YELLOW}[FIX] fusermount3 not found, creating symlink to fusermount...${NC}"
            local fm_path
            fm_path=$(command -v fusermount)
            if ln -sf "$fm_path" /usr/local/bin/fusermount3 2>/dev/null; then
                echo -e "${GREEN}✅ /usr/local/bin/fusermount3 → $fm_path symlink oluşturuldu.${NC}"
                log "Created symlink: /usr/local/bin/fusermount3 → $fm_path"
            else
                # sudo ile dene
                if sudo ln -sf "$fm_path" /usr/local/bin/fusermount3 2>/dev/null; then
                    echo -e "${GREEN}✅ symlink oluşturuldu (sudo ile / with sudo).${NC}"
                    log "Created symlink (sudo): /usr/local/bin/fusermount3 → $fm_path"
                else
                    echo -e "${YELLOW}⚠️  Symlink oluşturulamadı, devam ediliyor...${NC}"
                fi
            fi
        fi
    fi

    if [ "$fuse_ok" -eq 0 ]; then
        echo -e "${YELLOW}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "${YELLOW}║  FUSE kurulu değil! / FUSE is not installed!             ║${NC}"
        echo -e "${YELLOW}╚══════════════════════════════════════════════════════════╝${NC}"
        echo ""

        # Dağıtımı tespit et ve otomatik kur
        if command -v apt-get &>/dev/null; then
            echo -e "${CYAN}Debian/Ubuntu tespit edildi. FUSE kuruluyor...${NC}"
            echo -e "${CYAN}Debian/Ubuntu detected. Installing FUSE...${NC}"
            sudo apt-get update -qq && sudo apt-get install -y fuse3 fuse 2>/dev/null || \
            sudo apt-get install -y fuse 2>/dev/null
        elif command -v dnf &>/dev/null; then
            echo -e "${CYAN}Fedora/RHEL tespit edildi. FUSE kuruluyor...${NC}"
            sudo dnf install -y fuse fuse3 2>/dev/null
        elif command -v yum &>/dev/null; then
            echo -e "${CYAN}CentOS/RHEL tespit edildi. FUSE kuruluyor...${NC}"
            sudo yum install -y fuse 2>/dev/null
        elif command -v pacman &>/dev/null; then
            echo -e "${CYAN}Arch Linux tespit edildi. FUSE kuruluyor...${NC}"
            sudo pacman -S --noconfirm fuse3 fuse2 2>/dev/null
        elif command -v brew &>/dev/null; then
            echo -e "${CYAN}macOS tespit edildi. macFUSE kuruluyor...${NC}"
            brew install --cask macfuse 2>/dev/null
        else
            echo -e "${RED}Dağıtım tespit edilemedi. Manuel kurulum gerekli:${NC}"
            echo "  Debian/Ubuntu : sudo apt install fuse3"
            echo "  Fedora/RHEL   : sudo dnf install fuse3"
            echo "  Arch          : sudo pacman -S fuse3"
            echo "  macOS         : brew install --cask macfuse"
        fi

        # Kurulum sonrası tekrar kontrol
        if command -v fusermount3 &>/dev/null || command -v fusermount &>/dev/null; then
            echo -e "${GREEN}✅ FUSE başarıyla kuruldu / FUSE installed successfully.${NC}"
            sleep 1
        else
            echo -e "${RED}❌ FUSE kurulumu başarısız. Lütfen manuel kurun.${NC}"
            echo -e "${RED}❌ FUSE installation failed. Please install manually.${NC}"
            echo ""
            read -p "Yine de devam etmek ister misiniz? / Continue anyway? [y/N]: " cont
            [[ "$cont" =~ ^[Yy]$ ]] || exit 1
        fi
    fi

    # /dev/fuse erişim kontrolü
    if [ ! -c /dev/fuse ] 2>/dev/null; then
        echo -e "${YELLOW}⚠️  /dev/fuse mevcut değil. Docker/container ortamında mısınız?${NC}"
        echo -e "${YELLOW}⚠️  /dev/fuse not found. Are you in a Docker/container environment?${NC}"
        echo -e "${YELLOW}    Docker için: docker run --device /dev/fuse --cap-add SYS_ADMIN ...${NC}"
    fi

    # FUSE grubuna kullanıcıyı ekle (gerekirse)
    if getent group fuse &>/dev/null; then
        if ! groups "$USER" 2>/dev/null | grep -q fuse; then
            echo -e "${YELLOW}[FIX] Kullanıcı 'fuse' grubuna ekleniyor / Adding user to 'fuse' group...${NC}"
            sudo usermod -aG fuse "$USER" 2>/dev/null && \
                echo -e "${GREEN}  ✅ Eklendi (yeni oturumda aktif olacak) / Added (will be active in new session)${NC}"
        fi
    fi
}

# ============================================================
# HESAP LİSTELEME FONKSİYONLARI / ACCOUNT LISTING FUNCTIONS
# ============================================================

# Mevcut tüm gdrive hesaplarını listele / List all existing gdrive accounts
list_gdrive_accounts() {
    rclone listremotes 2>/dev/null | grep -E '^gdrive[0-9]+:$' | sed 's/:$//' | sort -V
}

# Mevcut tüm dropbox hesaplarını listele / List all existing dropbox accounts
list_dropbox_accounts() {
    rclone listremotes 2>/dev/null | grep -E '^dropbox[0-9]+:$' | sed 's/:$//' | sort -V
}

# Sonraki gdrive indeksini bul / Find next gdrive index
get_next_gdrive_index() {
    local max=0
    for remote in $(list_gdrive_accounts); do
        local num="${remote//gdrive/}"
        if [[ "$num" =~ ^[0-9]+$ ]] && [ "$num" -gt "$max" ]; then
            max=$num
        fi
    done
    echo $((max + 1))
}

# Sonraki dropbox indeksini bul / Find next dropbox index
get_next_dropbox_index() {
    local max=0
    for remote in $(list_dropbox_accounts); do
        local num="${remote//dropbox/}"
        if [[ "$num" =~ ^[0-9]+$ ]] && [ "$num" -gt "$max" ]; then
            max=$num
        fi
    done
    echo $((max + 1))
}

# ============================================================
# MOUNT DURUM KONTROLÜ / MOUNT STATUS CHECK
# ============================================================

is_mounted() {
    local mount_point="$1"
    if mountpoint -q "$mount_point" 2>/dev/null; then
        return 0
    elif mount | grep -q " $mount_point "; then
        return 0
    else
        return 1
    fi
}

show_mount_status() {
    print_banner
    echo -e "${BOLD}📊 MOUNT DURUMU / MOUNT STATUS${NC}"
    print_separator

    local gdrive_accounts
    mapfile -t gdrive_accounts < <(list_gdrive_accounts)
    local dropbox_accounts
    mapfile -t dropbox_accounts < <(list_dropbox_accounts)

    if [ ${#gdrive_accounts[@]} -eq 0 ] && [ ${#dropbox_accounts[@]} -eq 0 ]; then
        echo -e "${YELLOW}  Henüz hiç hesap eklenmemiş / No accounts added yet.${NC}"
    fi

    echo -e "\n${GREEN}${BOLD}📁 Google Drive Hesapları:${NC}"
    if [ ${#gdrive_accounts[@]} -eq 0 ]; then
        echo -e "  ${YELLOW}Kayıtlı hesap yok / No accounts registered${NC}"
    else
        for remote in "${gdrive_accounts[@]}"; do
            local mount_point="$HOME/$remote"
            if is_mounted "$mount_point"; then
                echo -e "  ${GREEN}✅ $remote  →  $mount_point  [MOUNTED]${NC}"
            else
                echo -e "  ${RED}❌ $remote  →  $mount_point  [NOT MOUNTED]${NC}"
            fi
        done
    fi

    echo -e "\n${CYAN}${BOLD}📦 Dropbox Hesapları:${NC}"
    if [ ${#dropbox_accounts[@]} -eq 0 ]; then
        echo -e "  ${YELLOW}Kayıtlı hesap yok / No accounts registered${NC}"
    else
        for remote in "${dropbox_accounts[@]}"; do
            local mount_point="$HOME/$remote"
            if is_mounted "$mount_point"; then
                echo -e "  ${GREEN}✅ $remote  →  $mount_point  [MOUNTED]${NC}"
            else
                echo -e "  ${RED}❌ $remote  →  $mount_point  [NOT MOUNTED]${NC}"
            fi
        done
    fi

    echo ""
    print_separator

    # Aktif rclone process'leri göster
    local procs
    procs=$(pgrep -a rclone 2>/dev/null | grep "rclone mount" || true)
    if [ -n "$procs" ]; then
        echo -e "\n${MAGENTA}${BOLD}⚙️  Aktif Rclone İşlemleri / Active Rclone Processes:${NC}"
        while IFS= read -r line; do
            echo -e "  ${MAGENTA}▸ $line${NC}"
        done <<< "$procs"
    fi
    echo ""
}

# ============================================================
# GOOGLE DRIVE FONKSİYONLARI / GOOGLE DRIVE FUNCTIONS
# ============================================================

add_gdrive_account() {
    print_banner
    echo -e "${GREEN}${BOLD}➕ YENİ GOOGLE DRIVE HESABI EKLE / ADD NEW GOOGLE DRIVE ACCOUNT${NC}"
    print_separator

    local index
    index=$(get_next_gdrive_index)
    local remote_name="gdrive${index}"
    local mount_point="$HOME/$remote_name"

    echo -e "${CYAN}Yeni hesap adı / New account name: ${BOLD}$remote_name${NC}"
    echo -e "${CYAN}Mount noktası / Mount point: ${BOLD}$mount_point${NC}"
    echo ""

    # Opsiyonel: özel isim kullanmak ister misiniz?
    read -p "$(echo -e "${YELLOW}Farklı bir isim kullanmak ister misiniz? (varsayılan: $remote_name) / Use a custom name? [y/N]: ${NC}")" use_custom
    if [[ "$use_custom" =~ ^[Yy]$ ]]; then
        while true; do
            read -p "$(echo -e "${YELLOW}Hesap adı (sadece harf/rakam, boşluksuz) / Account name (letters/numbers only): ${NC}")" custom_name
            if [[ "$custom_name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
                if rclone listremotes 2>/dev/null | grep -q "^${custom_name}:$"; then
                    echo -e "${RED}Bu isim zaten kullanımda / This name is already in use!${NC}"
                else
                    remote_name="$custom_name"
                    mount_point="$HOME/$remote_name"
                    break
                fi
            else
                echo -e "${RED}Geçersiz isim. Sadece harf, rakam, tire ve alt çizgi kullanın.${NC}"
                echo -e "${RED}Invalid name. Use only letters, numbers, hyphens, and underscores.${NC}"
            fi
        done
    fi

    print_separator
    echo -e "${YELLOW}📌 Team/Shared Drive kullanmak istiyor musunuz?${NC}"
    echo -e "${YELLOW}📌 Do you want to use a Team/Shared Drive?${NC}"
    read -p "$(echo -e "${YELLOW}[y/N]: ${NC}")" use_team_drive

    echo ""
    echo -e "${GREEN}Rclone Google Drive konfigürasyonu başlatılıyor...${NC}"
    echo -e "${GREEN}Starting rclone Google Drive configuration...${NC}"
    echo ""

    if [[ "$use_team_drive" =~ ^[Yy]$ ]]; then
        # Team Drive ile konfigürasyon
        echo -e "${CYAN}Not: Konfigürasyon sırasında 'team_drive' seçeneğini etkinleştirin.${NC}"
        echo -e "${CYAN}Note: Enable the 'team_drive' option during configuration.${NC}"
        echo ""
        rclone config create "$remote_name" drive scope=drive
        echo ""
        echo -e "${YELLOW}Team Drive ID'nizi girin / Enter your Team Drive ID:${NC}"
        echo -e "${YELLOW}(Google Drive'da Shared Drives > Drive URL'den alabilirsiniz)${NC}"
        read -p "Team Drive ID: " team_drive_id
        if [ -n "$team_drive_id" ]; then
            rclone config update "$remote_name" team_drive="$team_drive_id" 2>/dev/null || true
        fi
    else
        # Normal Drive konfigürasyonu
        rclone config create "$remote_name" drive scope=drive
    fi

    echo ""
    echo -e "${YELLOW}Hesabı yetkilendiriyorsunuz / Authorizing account...${NC}"
    rclone config reconnect "${remote_name}:"

    # Konfigürasyon başarılı mı kontrol et
    if rclone listremotes 2>/dev/null | grep -q "^${remote_name}:$"; then
        echo ""
        echo -e "${GREEN}✅ $remote_name başarıyla yapılandırıldı / successfully configured!${NC}"
        log "Google Drive account added: $remote_name"

        # Hemen mount etmek ister misiniz?
        read -p "$(echo -e "${YELLOW}Şimdi mount etmek ister misiniz? / Mount now? [Y/n]: ${NC}")" mount_now
        if [[ ! "$mount_now" =~ ^[Nn]$ ]]; then
            mount_gdrive_single "$remote_name"
        fi
    else
        echo -e "${RED}❌ Konfigürasyon başarısız / Configuration failed!${NC}"
        log "ERROR: Failed to add Google Drive account: $remote_name"
    fi
}

do_rclone_mount() {
    local remote_name="$1"
    local mount_point="$2"

    # Ortak mount parametreleri
    local MOUNT_OPTS=(
        --vfs-cache-mode writes
        --vfs-cache-max-age 24h
        --vfs-cache-max-size 1G
        --dir-cache-time 30m
        --poll-interval 30s
        --allow-non-empty
        --no-modtime
        --transfers 4
        --log-file "$LOG_FILE"
        --log-level INFO
    )

    # fusermount3 yoksa FUSE binary yolunu elle ver
    local fuse_bin=""
    if command -v fusermount3 &>/dev/null; then
        fuse_bin=$(command -v fusermount3)
    elif command -v fusermount &>/dev/null; then
        fuse_bin=$(command -v fusermount)
    fi

    # RCLONE_FUSE_PROGRAM env değişkeni ile fusermount3 yerine fusermount kullandır
    if [ -n "$fuse_bin" ]; then
        export RCLONE_FUSE_PROGRAM="$fuse_bin"
    fi

    # Yöntem 1: --daemon ile dene
    echo -e "  ${CYAN}[1/3] --daemon modu deneniyor...${NC}"
    rclone mount "${remote_name}:" "$mount_point" "${MOUNT_OPTS[@]}" --daemon 2>>"$LOG_FILE"
    sleep 3
    if is_mounted "$mount_point"; then
        return 0
    fi

    # Yöntem 2: nohup ile arka plana al
    echo -e "  ${CYAN}[2/3] nohup modu deneniyor...${NC}"
    nohup rclone mount "${remote_name}:" "$mount_point" "${MOUNT_OPTS[@]}" \
        >> "$LOG_FILE" 2>&1 &
    disown $!
    sleep 4
    if is_mounted "$mount_point"; then
        return 0
    fi

    # Yöntem 3: setsid ile izole et
    echo -e "  ${CYAN}[3/3] setsid modu deneniyor...${NC}"
    setsid rclone mount "${remote_name}:" "$mount_point" "${MOUNT_OPTS[@]}" \
        >> "$LOG_FILE" 2>&1 &
    disown $!
    sleep 4
    if is_mounted "$mount_point"; then
        return 0
    fi

    return 1
}

mount_gdrive_single() {
    local remote_name="$1"
    local mount_point="$HOME/$remote_name"

    if is_mounted "$mount_point"; then
        echo -e "${YELLOW}⚠️  $remote_name zaten mount edilmiş / already mounted: $mount_point${NC}"
        return
    fi

    mkdir -p "$mount_point"
    echo -e "${GREEN}$remote_name → $mount_point mount ediliyor / mounting...${NC}"

    if do_rclone_mount "$remote_name" "$mount_point"; then
        echo -e "${GREEN}✅ $remote_name başarıyla mount edildi → $mount_point${NC}"
        log "Mounted: $remote_name → $mount_point"
    else
        echo -e "${RED}❌ Mount başarısız / Mount failed: $remote_name${NC}"
        echo -e "${YELLOW}Olası nedenler / Possible causes:${NC}"
        echo -e "  ${YELLOW}• FUSE kurulu değil → sudo apt install fuse3${NC}"
        echo -e "  ${YELLOW}• /dev/fuse erişimi yok → Container'da --device /dev/fuse gerekli${NC}"
        echo -e "  ${YELLOW}• rclone yetkilendirmesi eksik → 'rclone config reconnect ${remote_name}:'${NC}"
        echo -e "  ${YELLOW}• Log: $LOG_FILE${NC}"
        log "ERROR: Failed to mount $remote_name → $mount_point (all methods failed)"
    fi
}

mount_all_gdrive() {
    print_banner
    echo -e "${GREEN}${BOLD}📁 TÜM GOOGLE DRIVE HESAPLARINI MOUNT ET${NC}"
    print_separator

    local accounts
    mapfile -t accounts < <(list_gdrive_accounts)

    if [ ${#accounts[@]} -eq 0 ]; then
        echo -e "${YELLOW}Kayıtlı Google Drive hesabı yok. Önce hesap ekleyin.${NC}"
        echo -e "${YELLOW}No registered Google Drive accounts. Please add an account first.${NC}"
        press_enter
        return
    fi

    echo -e "${CYAN}${#accounts[@]} hesap bulundu / ${#accounts[@]} account(s) found${NC}"
    echo ""

    for remote in "${accounts[@]}"; do
        mount_gdrive_single "$remote"
    done

    echo ""
    echo -e "${GREEN}${BOLD}✅ Tüm Google Drive işlemleri tamamlandı / All Google Drive operations completed.${NC}"
    press_enter
}

select_and_mount_gdrive() {
    print_banner
    echo -e "${GREEN}${BOLD}📁 GOOGLE DRIVE HESABI SEÇ VE MOUNT ET${NC}"
    print_separator

    local accounts
    mapfile -t accounts < <(list_gdrive_accounts)

    if [ ${#accounts[@]} -eq 0 ]; then
        echo -e "${YELLOW}Kayıtlı Google Drive hesabı yok.${NC}"
        press_enter
        return
    fi

    echo -e "${CYAN}Mevcut hesaplar / Available accounts:${NC}"
    echo ""
    for i in "${!accounts[@]}"; do
        local remote="${accounts[$i]}"
        local mount_point="$HOME/$remote"
        local status=""
        if is_mounted "$mount_point"; then
            status="${GREEN}[MOUNTED]${NC}"
        else
            status="${RED}[NOT MOUNTED]${NC}"
        fi
        echo -e "  ${BOLD}$((i+1)))${NC} $remote  $status"
    done
    echo -e "  ${BOLD}0)${NC} Geri / Back"
    echo ""
    read -p "$(echo -e "${YELLOW}Seçiminiz / Your choice: ${NC}")" choice

    if [[ "$choice" == "0" ]]; then
        return
    fi

    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#accounts[@]}" ]; then
        local selected="${accounts[$((choice-1))]}"
        echo ""
        mount_gdrive_single "$selected"
        press_enter
    else
        echo -e "${RED}Geçersiz seçim / Invalid choice${NC}"
        press_enter
    fi
}

