# ============================================================
# UNMOUNT FONKSİYONLARI / UNMOUNT FUNCTIONS
# ============================================================

unmount_remote() {
    local mount_point="$1"
    local remote_name="$2"

    if ! is_mounted "$mount_point"; then
        echo -e "${YELLOW}⚠️  $remote_name zaten unmount edilmiş / already unmounted${NC}"
        return
    fi

    echo -e "${YELLOW}$remote_name unmount ediliyor / unmounting...${NC}"

    # Fusermount ile dene / Try with fusermount
    if command -v fusermount &> /dev/null; then
        fusermount -u "$mount_point" 2>/dev/null && {
            echo -e "${GREEN}✅ $remote_name başarıyla unmount edildi / successfully unmounted${NC}"
            log "Unmounted: $remote_name → $mount_point"
            return
        }
    fi

    # umount ile dene / Try with umount
    umount "$mount_point" 2>/dev/null && {
        echo -e "${GREEN}✅ $remote_name başarıyla unmount edildi / successfully unmounted${NC}"
        log "Unmounted: $remote_name → $mount_point"
        return
    }

    # Zorla unmount / Force unmount
    echo -e "${YELLOW}Zorla unmount deneniyor / Trying force unmount...${NC}"
    fusermount -uz "$mount_point" 2>/dev/null || umount -l "$mount_point" 2>/dev/null && {
        echo -e "${GREEN}✅ $remote_name zorla unmount edildi / force unmounted${NC}"
        log "Force unmounted: $remote_name → $mount_point"
        return
    }

    echo -e "${RED}❌ Unmount başarısız / Unmount failed for $remote_name${NC}"
    log "ERROR: Failed to unmount $remote_name → $mount_point"
}

