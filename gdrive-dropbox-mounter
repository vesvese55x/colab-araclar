# ============================================================
# SYSTEMD SERVİSİ OLUŞTUR / CREATE SYSTEMD SERVICE
# ============================================================

create_systemd_service() {
    print_banner
    echo -e "${MAGENTA}${BOLD}⚙️  SYSTEMD OTOMATİK BAŞLATMA / SYSTEMD AUTO-START${NC}"
    print_separator

    if ! command -v systemctl &> /dev/null; then
        echo -e "${RED}systemd bu sistemde mevcut değil / systemd is not available on this system.${NC}"
        press_enter
        return
    fi

    local gdrive_accounts
    mapfile -t gdrive_accounts < <(list_gdrive_accounts)
    local dropbox_accounts
    mapfile -t dropbox_accounts < <(list_dropbox_accounts)
    local all_accounts=("${gdrive_accounts[@]}" "${dropbox_accounts[@]}")

    if [ ${#all_accounts[@]} -eq 0 ]; then
        echo -e "${YELLOW}Kayıtlı hesap yok / No registered accounts.${NC}"
        press_enter
        return
    fi

    echo -e "${CYAN}Aşağıdaki hesaplar için servis oluşturulacak:${NC}"
    echo -e "${CYAN}Services will be created for:${NC}"
    for remote in "${all_accounts[@]}"; do
        echo -e "  ${BOLD}▸${NC} $remote"
    done
    echo ""

    local SERVICE_DIR="$HOME/.config/systemd/user"
    mkdir -p "$SERVICE_DIR"

    local SCRIPT_PATH
    SCRIPT_PATH=$(realpath "$0")

    for remote in "${all_accounts[@]}"; do
        local mount_point="$HOME/$remote"
        local service_file="$SERVICE_DIR/rclone-${remote}.service"

        cat > "$service_file" << EOF
[Unit]
Description=Rclone Mount - ${remote}
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
ExecStartPre=/bin/mkdir -p ${mount_point}
ExecStart=/usr/bin/rclone mount ${remote}: ${mount_point} \
    --vfs-cache-mode writes \
    --vfs-cache-max-age 24h \
    --vfs-cache-max-size 1G \
    --dir-cache-time 30m \
    --poll-interval 30s \
    --allow-non-empty \
    --log-file ${LOG_FILE} \
    --log-level INFO
ExecStop=/bin/fusermount -u ${mount_point}
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
EOF

        echo -e "${GREEN}✅ Servis oluşturuldu / Service created: $service_file${NC}"
    done

    echo ""
    systemctl --user daemon-reload 2>/dev/null

    read -p "$(echo -e "${YELLOW}Servisleri şimdi etkinleştirip başlatmak ister misiniz? / Enable and start services now? [Y/n]: ${NC}")" enable_now
    if [[ ! "$enable_now" =~ ^[Nn]$ ]]; then
        for remote in "${all_accounts[@]}"; do
            systemctl --user enable "rclone-${remote}.service" 2>/dev/null && \
                echo -e "${GREEN}  ✅ rclone-${remote} etkinleştirildi / enabled${NC}"
            systemctl --user start "rclone-${remote}.service" 2>/dev/null && \
                echo -e "${GREEN}  ✅ rclone-${remote} başlatıldı / started${NC}"
        done
    fi

    echo ""
    echo -e "${CYAN}Lingering etkinleştirmek için (kullanıcı logout olsa bile çalışsın):${NC}"
    echo -e "${CYAN}To enable lingering (run even after user logout):${NC}"
    echo -e "  ${BOLD}loginctl enable-linger \$USER${NC}"
    echo ""
    press_enter
}

