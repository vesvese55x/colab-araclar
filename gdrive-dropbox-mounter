    else
        echo -e "  ${RED}❌ fusermount3 bulunamadı${NC}"
    fi

    echo -e "${BOLD}2. fusermount kontrolü:${NC}"
    if command -v fusermount &>/dev/null; then
        echo -e "  ${GREEN}✅ fusermount bulundu: $(command -v fusermount)${NC}"
    else
        echo -e "  ${RED}❌ fusermount bulunamadı${NC}"
    fi

    echo -e "${BOLD}3. /dev/fuse kontrolü:${NC}"
    if [ -c /dev/fuse ]; then
