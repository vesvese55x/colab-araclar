        dropbox_count=$(list_dropbox_accounts | wc -l)
        local mounted_count
        mounted_count=$(mount | grep -c "rclone" 2>/dev/null || echo 0)

        echo -e "  ${GREEN}📁 Google Drive:${NC} ${gdrive_count} hesap  |  ${CYAN}📦 Dropbox:${NC} ${dropbox_count} hesap  |  ${MAGENTA}✅ Aktif mount:${NC} ${mounted_count}"
        echo ""
        print_separator
        echo ""
        echo -e "  ${BOLD}1)${NC} ${GREEN}📁 Google Drive işlemleri / Google Drive operations${NC}"
        echo -e "  ${BOLD}2)${NC} ${CYAN}📦 Dropbox işlemleri / Dropbox operations${NC}"
        echo -e "  ${BOLD}3)${NC} ${MAGENTA}🚀 Tüm hesapları mount et / Mount all accounts${NC}"
        echo -e "  ${BOLD}4)${NC} ${YELLOW}⏏  Unmount işlemleri / Unmount operations${NC}"
        echo -e "  ${BOLD}5)${NC} ${BOLD}📊 Mount durumu / Mount status${NC}"
        echo -e "  ${BOLD}6)${NC} ${BOLD}📋 Tüm hesapları listele / List all accounts${NC}"
        echo -e "  ${BOLD}7)${NC} ${RED}🗑️  Hesap sil / Delete account${NC}"
        echo -e "  ${BOLD}8)${NC} ${MAGENTA}⚙️  Systemd servisi oluştur / Create systemd service${NC}"
        echo -e "  ${BOLD}9)${NC} ${BOLD}📜 Logları görüntüle / View logs${NC}"
        echo -e "  ${BOLD}F)${NC} ${MAGENTA}🔍 FUSE tanı & düzelt / FUSE diagnostics & fix${NC}"
        echo -e "  ${BOLD}0)${NC} ${RED}🚪 Çıkış / Exit${NC}"
        echo ""
        print_separator
        read -p "$(echo -e "${YELLOW}Seçiminiz / Your choice: ${NC}")" choice

        case "$choice" in
            1) gdrive_menu ;;
            2) dropbox_menu ;;
            3) mount_all ;;
            4) unmount_menu ;;
            5) show_mount_status; press_enter ;;
            6) list_all_accounts ;;
            7) delete_account_menu ;;
            8) create_systemd_service ;;
            9) view_logs ;;
            [Ff]) fuse_diagnostics ;;
            0)
                echo ""
                echo -e "${RED}${BOLD}Çıkış yapılıyor / Exiting...${NC}"
                echo -e "${YELLOW}Not: Mount edilmiş sürücüler arka planda çalışmaya devam eder.${NC}"
                echo -e "${YELLOW}Note: Mounted drives will continue running in the background.${NC}"
                echo ""
                exit 0
                ;;
            *)
                echo -e "${RED}Geçersiz seçim / Invalid choice. Lütfen tekrar deneyin / Please try again.${NC}"
                sleep 1
                ;;
        esac
    done
}

# ============================================================
# BAŞLANGIÇ / STARTUP
# ============================================================

check_rclone
check_fuse_and_fix

# ~/.local/bin PATH'de yoksa ekle (fusermount3 symlink için)
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# Başlangıçta fusermount3 hâlâ yoksa ve fusermount varsa → otomatik symlink
if ! command -v fusermount3 &>/dev/null && command -v fusermount &>/dev/null; then
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(command -v fusermount)" "$HOME/.local/bin/fusermount3" 2>/dev/null
    log "Auto-symlink: fusermount3 → $(command -v fusermount)"
fi

# Log dosyasını başlat
touch "$LOG_FILE"
log "=== Rclone Mount Manager started ==="
log "PATH: $PATH"
log "fusermount3: $(command -v fusermount3 2>/dev/null || echo 'NOT FOUND')"
log "fusermount : $(command -v fusermount  2>/dev/null || echo 'NOT FOUND')"

# Ana menüyü başlat
main_menu
